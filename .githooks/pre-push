#!/usr/bin/env bash
set -euo pipefail

echo "Running backend tests..."
(
  cd backend
  mvn clean test
)

echo "Starting backend for frontend integration tests..."
(
  cd backend
  nohup ./mvnw -B -DskipTests spring-boot:run > /tmp/justorder-backend-prepush.log 2>&1 &
  echo $! > /tmp/justorder-backend-prepush.pid
)

cleanup() {
  if [[ -f /tmp/justorder-backend-prepush.pid ]]; then
    kill "$(cat /tmp/justorder-backend-prepush.pid)" 2>/dev/null || true
    rm -f /tmp/justorder-backend-prepush.pid
  fi
}

trap cleanup EXIT

echo "Waiting for backend to be ready..."
for i in {1..60}; do
  if curl -fsS http://localhost:8080/api/restaurants/search >/dev/null; then
    echo "Backend is ready."
    break
  fi

  if [[ "$i" -eq 60 ]]; then
    echo "Backend did not become ready in time."
    tail -n 200 /tmp/justorder-backend-prepush.log || true
    exit 1
  fi

  sleep 2
done

echo "Running frontend tests..."
(
  cd frontend
  npm install
  CI=true npm test -- --watchAll=false
)

echo "All tests passed. Push allowed."
